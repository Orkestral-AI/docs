      "light": "#ffffff",
      "dark": "#07060c"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "pages": ["en/introduction", "en/installation", "en/quickstart"]
